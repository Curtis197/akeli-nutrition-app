# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — AI Assistant + vectorisation
OPENAI_API_KEY=sk-...

# Gemini — Traduction langues africaines
GEMINI_API_KEY=your-gemini-key

# Firebase Cloud Messaging — Push notifications
FCM_SERVER_KEY=your-fcm-server-key

# -----------------------------------------------------------------------
# Abonnement utilisateur — via Google Play & App Store (in-app purchase)
# Les utilisateurs paient directement via leur store, pas via Stripe
# -----------------------------------------------------------------------

# Apple App Store — Shared Secret (App Store Connect > App > In-App Purchases)
APPLE_SHARED_SECRET=your-apple-shared-secret

# Google Play — Service Account JSON (doit avoir le rôle "Financial data viewer")
# Coller le contenu JSON complet sur une seule ligne
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Android package name (doit correspondre à ce que tu as configuré dans Google Play Console)
ANDROID_PACKAGE_NAME=app.akeli.nutrition

# -----------------------------------------------------------------------
# Paiements créateurs — via Stripe (site web Akeli uniquement, pas dans l'app)
# -----------------------------------------------------------------------

# Stripe Connect — pour reverser les gains aux créateurs
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Python Service (Railway)
PYTHON_SERVICE_URL=https://akeli-engine.railway.app
