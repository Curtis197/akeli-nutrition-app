SELECT 
  c.id as creator_id,
  COUNT(DISTINCT rc.user_id) as total_unique_consumers,
  COUNT(rc.id) as total_recipe_consumptions,
  
  -- Aggregate demographics across all recipes
  AVG(rd.age_avg) as age_avg,
  
  -- Merge age ranges (sum across all recipes)
  jsonb_build_object(
    '18-25', SUM((rd.age_ranges->>'18-25')::int),
    '26-35', SUM((rd.age_ranges->>'26-35')::int),
    '36-45', SUM((rd.age_ranges->>'36-45')::int),
    '46-55', SUM((rd.age_ranges->>'46-55')::int),
    '56+', SUM((rd.age_ranges->>'56+')::int)
  ) as age_ranges,
  
  -- Merge gender distribution
  jsonb_build_object(
    'male', SUM((rd.gender_distribution->>'male')::int),
    'female', SUM((rd.gender_distribution->>'female')::int),
    'other', SUM((rd.gender_distribution->>'other')::int),
    'not_specified', SUM((rd.gender_distribution->>'not_specified')::int)
  ) as gender_distribution,
  
  -- Weight change
  AVG(rd.avg_weight_change) as avg_weight_change,
  SUM(rd.avg_weight_change * rd.weight_loss_users_count) as total_kg_lost,
  
  -- Goal distribution
  jsonb_build_object(
    'weight_loss', SUM((rd.goal_distribution->>'weight_loss')::int),
    'muscle_gain', SUM((rd.goal_distribution->>'muscle_gain')::int),
    'maintenance', SUM((rd.goal_distribution->>'maintenance')::int)
  ) as goal_distribution,
  
  -- Overall success
  AVG(rd.success_rate) as overall_success_rate,
  
  now() as last_updated

FROM creator c
JOIN receipe r ON r.creator_id = c.id
JOIN recipe_consumptions rc ON rc.recipe_id = r.id
LEFT JOIN recipe_demographics rd ON rd.recipe_id = r.id

GROUP BY c.id

ON CONFLICT (creator_id) DO UPDATE
SET 
  total_unique_consumers = EXCLUDED.total_unique_consumers,
  total_recipe_consumptions = EXCLUDED.total_recipe_consumptions,
