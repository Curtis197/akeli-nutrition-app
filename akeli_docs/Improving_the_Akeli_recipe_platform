Data Processing Strategy
Real-Time (Triggers)
Use triggers for immediate counters that need to be instant:
sql-- Example: Increment view counter when recipe is viewed
CREATE OR REPLACE FUNCTION increment_recipe_views()
RETURNS TRIGGER AS $$
BEGIN
  UPDATE recipe_performance_metrics
  SET 
    total_views = total_views + 1,
    views_last_7d = views_last_7d + 1,
    views_last_30d = views_last_30d + 1,
    last_updated = now()
  WHERE recipe_id = NEW.recipe_id;
  
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_increment_views
AFTER INSERT ON recipe_views
FOR EACH ROW
EXECUTE FUNCTION increment_recipe_views();
Use triggers for:

Simple counters (views, saves, consumptions)
Revenue totals
Immediate updates (user sees latest data)


Scheduled (Cron Jobs)
Use cron for heavy analytics that don't need to be instant:
Cron Job 1: Daily Stats (Midnight)
sql-- Edge Function or pg_cron
INSERT INTO creator_daily_stats (creator_id, stat_date, total_views, total_consumptions, revenue_earned)
SELECT 
  c.id,
  CURRENT_DATE - 1,
  COUNT(DISTINCT rv.id),
  COUNT(DISTINCT rc.id),
  COUNT(DISTINCT rc.id) / 30.0 -- €1 per 30
FROM creator c
LEFT JOIN receipe r ON r.creator_id = c.id
LEFT JOIN recipe_views rv ON rv.recipe_id = r.id 
  AND rv.viewed_at >= CURRENT_DATE - 1 
  AND rv.viewed_at < CURRENT_DATE
LEFT JOIN recipe_consumptions rc ON rc.recipe_id = r.id
  AND rc.consumed_at >= CURRENT_DATE - 1
  AND rc.consumed_at < CURRENT_DATE
GROUP BY c.id
ON CONFLICT (creator_id, stat_date) DO UPDATE
SET 
  total_views = EXCLUDED.total_views,
  total_consumptions = EXCLUDED.total_consumptions,
  revenue_earned = EXCLUDED.revenue_earned;

Cron Job 2: Weekly Summary (Sunday Night)
sql-- Aggregate weekly data + calculate growth
INSERT INTO creator_weekly_summary (creator_id, week_start, week_end, total_views, views_growth_pct)
SELECT 
  creator_id,
  date_trunc('week', CURRENT_DATE - interval '1 week'),
  date_trunc('week', CURRENT_DATE) - interval '1 day',
  SUM(total_views),
  (SUM(total_views) - LAG(SUM(total_views)) OVER (PARTITION BY creator_id ORDER BY week_start)) 
    / NULLIF(LAG(SUM(total_views)) OVER (PARTITION BY creator_id ORDER BY week_start), 0) * 100
FROM creator_daily_stats
WHERE stat_date >= date_trunc('week', CURRENT_DATE - interval '1 week')
  AND stat_date < date_trunc('week', CURRENT_DATE)
GROUP BY creator_id;
```

