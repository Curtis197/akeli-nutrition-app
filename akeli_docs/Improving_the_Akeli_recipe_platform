CREATE OR REPLACE FUNCTION track_meal_abandonment()
RETURNS void AS $$
BEGIN
  INSERT INTO meal_plan_abandonment (
    meal_id, recipe_id, creator_id, user_id, user_name,
    planned_date, planned_meal_type, added_to_plan_at, was_cooked
  )
  SELECT 
    m.id,
    m.receipe_id,
    r.creator_id,
    m.user_id,
    u.user_name,
    m.meal_date,
    m.meal_type,
    m.created_at,
    m.consumed
  FROM meal m
  JOIN receipe r ON r.id = m.receipe_id
  JOIN users u ON u.id = m.user_id
  WHERE m.meal_date < CURRENT_DATE - 1 -- past meals only
    AND NOT EXISTS (
      SELECT 1 FROM meal_plan_abandonment mpa 
      WHERE mpa.meal_id = m.id
    )
  ON CONFLICT DO NOTHING;
END;
$$ LANGUAGE plpgsql;
