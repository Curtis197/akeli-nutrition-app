sql-- Aggregate daily search trends
INSERT INTO seo_search_trends (trend_date, keyword, search_count, unique_searchers, click_through_rate)
SELECT 
  CURRENT_DATE - 1 as trend_date,
  query_normalized,
  COUNT(*) as search_count,
  COUNT(DISTINCT user_id) as unique_searchers,
  AVG(CASE WHEN clicked_recipe THEN 1 ELSE 0 END) as click_through_rate
FROM search_events
WHERE searched_at >= CURRENT_DATE - 1
  AND searched_at < CURRENT_DATE
GROUP BY query_normalized
ON CONFLICT (trend_date, keyword) DO UPDATE
SET 
  search_count = EXCLUDED.search_count,
  unique_searchers = EXCLUDED.unique_searchers,
  click_through_rate = EXCLUDED.click_through_rate;

Cron Job 2: Update Recipe Rankings (Daily, 3am)
sql-- Calculate current rankings for all keywords
WITH ranked_recipes AS (
  SELECT 
    se.query_normalized as keyword,
    r.id as recipe_id,
    r.creator_id,
    COUNT(*) as impressions,
    SUM(CASE WHEN sc.id IS NOT NULL THEN 1 ELSE 0 END) as clicks,
    -- Ranking algorithm (simplified - you'd make this more sophisticated)
    ROW_NUMBER() OVER (
      PARTITION BY se.query_normalized 
      ORDER BY 
        COUNT(sc.id) DESC, -- clicks
        rpm.popularity_score DESC, -- recipe quality
        rpm.total_consumptions DESC -- proven success
    ) as position
  FROM search_events se
  LEFT JOIN search_clicks sc ON sc.search_event_id = se.id
  JOIN receipe r ON r.id = sc.recipe_id
  JOIN recipe_performance_metrics rpm ON rpm.recipe_id = r.id
  WHERE se.searched_at >= CURRENT_DATE - 7 -- last 7 days
  GROUP BY se.query_normalized, r.id, r.creator_id, rpm.popularity_score, rpm.total_consumptions
)
INSERT INTO seo_recipe_rankings (
  keyword, recipe_id, creator_id, current_position, 
  previous_position, impressions, clicks, ranking_date
)
SELECT 
  rr.keyword,
  rr.recipe_id,
  rr.creator_id,
  rr.position as current_position,
  COALESCE(prev.current_position, 999) as previous_position,
  rr.impressions,
  rr.clicks,
  CURRENT_DATE
FROM ranked_recipes rr
LEFT JOIN seo_recipe_rankings prev 
  ON prev.recipe_id = rr.recipe_id 
  AND prev.keyword = rr.keyword
  AND prev.ranking_date = CURRENT_DATE - 1
WHERE rr.position <= 20 -- only track top 20
ON CONFLICT (keyword, recipe_id, ranking_date) DO UPDATE
SET 
  current_position = EXCLUDED.current_position,
  previous_position = EXCLUDED.previous_position,
  impressions = EXCLUDED.impressions,
  clicks = EXCLUDED.clicks;
