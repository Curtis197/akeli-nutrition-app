Final Ranking Score Calculation
Complete SQL Formula:
sqlCREATE OR REPLACE FUNCTION calculate_recipe_ranking_score(
  p_recipe_id bigint,
  p_user_id bigint DEFAULT NULL -- for personalization
)
RETURNS numeric AS $$
DECLARE
  v_cooking_rate_score numeric;
  v_quality_score numeric;
  v_engagement_score numeric;
  v_freshness_bonus numeric;
  v_creator_boost numeric;
  v_personalization numeric := 0;
  v_final_score numeric;
BEGIN
  
  -- 1. COOKING RATE (50% weight)
  SELECT 
    -- Recent weighted cooking rate
    ((rpm.consumptions_last_7d * 0.40) + 
     (rpm.consumptions_last_30d * 0.35) + 
     (rpm.total_consumptions * 0.25)) 
    / NULLIF(rpm.total_views, 0) * 1000 -- scale up
  INTO v_cooking_rate_score
  FROM recipe_performance_metrics rpm
  WHERE rpm.recipe_id = p_recipe_id;
  
  v_cooking_rate_score := LEAST(v_cooking_rate_score, 100);
  
  
  -- 2. QUALITY SCORE (30% weight)
  SELECT 
    (
      -- 2a. Bayesian average rating (40%)
      ((rpm.avg_rating * rpm.rating_count + 4.2 * 10) / 
       (rpm.rating_count + 10) / 5.0 * 100 * 0.40) +
      
      -- 2b. Completion rate (35%)
      (rpm.completion_rate * 0.35) +
      
      -- 2c. Recipe quality metrics (25%)
      ((
        (CASE WHEN r.photo_count >= 3 THEN 15
              WHEN r.photo_count >= 1 THEN 10
              ELSE 0 END) +
        (CASE WHEN r.avg_step_word_count > 15 THEN 10 ELSE 5 END) +
        (CASE WHEN r.all_ingredients_have_quantities THEN 10 ELSE 0 END) +
        (CASE WHEN r.time_of_cooking_min > 0 THEN 5 ELSE 0 END) +
        (CASE WHEN r.has_macros THEN 5 ELSE 0 END)
      ) / 45.0 * 100 * 0.25)
    )
  INTO v_quality_score
  FROM recipe_performance_metrics rpm
  JOIN receipe r ON r.id = rpm.recipe_id
  WHERE rpm.recipe_id = p_recipe_id;
  
  
  -- 3. ENGAGEMENT SCORE (15% weight)
  SELECT 
    (
      -- 3a. Like score (40%)
      ((LOG(rpm.total_likes + 1) * 30 + 
        (rpm.total_likes::numeric / NULLIF(rpm.total_views, 0) * 100 * 70)) 
       * 0.40) +
      
      -- 3b. Save score (35%)
      (((rpm.total_saves::numeric / NULLIF(rpm.total_views, 0) * 100 * 0.60) +
        (rpm.save_to_cook_rate * 0.40)) * 0.35) +
      
      -- 3c. Share score (15%)
      ((rpm.total_shares::numeric / NULLIF(rpm.total_views, 0) * 100 * 50) * 0.15) +
      
      -- 3d. Comment score (10%)
      (((rpm.comment_count::numeric / NULLIF(rpm.total_views, 0) * 1000 * 0.50) +
        (rpm.positive_comment_ratio * 50)) * 0.10)
    )
  INTO v_engagement_score
  FROM recipe_performance_metrics rpm
  WHERE rpm.recipe_id = p_recipe_id;
  
  v_engagement_score := LEAST(v_engagement_score, 100);
  
  
  -- 4. FRESHNESS BONUS (5% weight)
  SELECT 
    CASE
      WHEN CURRENT_DATE - r.created_at::date <= 7 THEN 100
      WHEN CURRENT_DATE - r.created_at::date <= 30 THEN 75
      WHEN CURRENT_DATE - r.created_at::date <= 90 THEN 50
      WHEN CURRENT_DATE - r.created_at::date <= 180 THEN 25
      ELSE 0
    END
  INTO v_freshness_bonus
  FROM receipe r
  WHERE r.id = p_recipe_id;
  
  
  -- 5. CREATOR REPUTATION (small boost)
  SELECT 
    LEAST(LOG(SUM(rpm2.total_consumptions) + 1) * 0.10, 10)
  INTO v_creator_boost
  FROM receipe r
  JOIN recipe_performance_metrics rpm2 ON rpm2.creator_id = r.creator_id
  WHERE r.id = p_recipe_id;
  
  
  -- 6. PERSONALIZATION (Pro users only)
  IF p_user_id IS NOT NULL THEN
    SELECT 
      (
        (CASE WHEN r.primary_goal = ug.target_type THEN 15 ELSE 0 END) +
        (CASE WHEN r.diet_compatible_with_user THEN 15 ELSE 0 END) +
        (CASE WHEN r.difficulty <= up.cooking_level THEN 10 ELSE 0 END) +
        (CASE WHEN r.time_of_cooking_min <= up.preferred_cooking_time THEN 10 ELSE 0 END)
      )
    INTO v_personalization
    FROM receipe r
    LEFT JOIN user_goal ug ON ug.user_id = p_user_id
    LEFT JOIN user_preferences up ON up.user_id = p_user_id
    WHERE r.id = p_recipe_id;
  END IF;
  
  
  -- FINAL CALCULATION
  v_final_score := 
    (COALESCE(v_cooking_rate_score, 0) * 0.50) +
    (COALESCE(v_quality_score, 0) * 0.30) +
    (COALESCE(v_engagement_score, 0) * 0.15) +
    (COALESCE(v_freshness_bonus, 0) * 0.05) +
    COALESCE(v_creator_boost, 0) +
    (COALESCE(v_personalization, 0) * 0.10);
  
  RETURN ROUND(v_final_score, 2);
  
END;
$$ LANGUAGE plpgsql;

