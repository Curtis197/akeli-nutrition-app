Trigger: Update Metrics on Meal Consumption
Real-time updates when meals are consumed:
sqlCREATE OR REPLACE FUNCTION update_plan_to_cook_metrics()
RETURNS TRIGGER AS $$
BEGIN
  -- When meal is marked as consumed
  IF NEW.consumed = true AND (OLD.consumed = false OR OLD.consumed IS NULL) THEN
    UPDATE recipe_performance_metrics
    SET 
      meals_cooked_lifetime = meals_cooked_lifetime + 1,
      meals_cooked_last_7d = meals_cooked_last_7d + 1,
      meals_cooked_last_30d = meals_cooked_last_30d + 1,
      plan_to_cook_rate = 
        (meals_cooked_lifetime + 1)::numeric / 
        NULLIF(meals_planned_lifetime, 0) * 100
    WHERE recipe_id = NEW.receipe_id;
  END IF;
  
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_update_cook_metrics
AFTER UPDATE OF consumed ON meal
FOR EACH ROW
EXECUTE FUNCTION update_plan_to_cook_metrics();

