sql-- Trigger on recipe save
CREATE OR REPLACE FUNCTION auto_calculate_macros()
RETURNS TRIGGER AS $$
DECLARE
  v_total_calories numeric := 0;
  v_total_protein numeric := 0;
  v_total_carbs numeric := 0;
  v_total_fat numeric := 0;
BEGIN
  -- Sum up ingredient macros
  SELECT 
    SUM(calories_per_unit * quantity),
    SUM(protein_per_unit * quantity),
    SUM(carbs_per_unit * quantity),
    SUM(fat_per_unit * quantity)
  INTO v_total_calories, v_total_protein, v_total_carbs, v_total_fat
  FROM ingredients i
  JOIN nutrition_data nd ON nd.ingredient_name = i.name
  WHERE i.receipe_id = NEW.id;
  
  -- Update recipe with calculated macros
  UPDATE receipe_macro
  SET 
    quantity = CASE 
      WHEN type = 'calories' THEN v_total_calories
      WHEN type = 'protein' THEN v_total_protein
      WHEN type = 'carbs' THEN v_total_carbs
      WHEN type = 'fat' THEN v_total_fat
    END
  WHERE receipe_id = NEW.id;
  
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;
