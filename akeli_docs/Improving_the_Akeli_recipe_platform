-- Function: Check if creator can analyze
CREATE OR REPLACE FUNCTION can_analyze_seo(p_creator_id uuid)
RETURNS boolean AS $$
DECLARE
  v_tier text;
  v_used int;
  v_allowed int;
BEGIN
  -- Get user tier
  SELECT 
    CASE WHEN us.plan = 'pro' THEN 'pro' ELSE 'free' END
  INTO v_tier
  FROM creator c
  JOIN users u ON u.id = (SELECT user_id FROM creator WHERE id = p_creator_id)
  LEFT JOIN user_subscription us ON us.user_id = u.id AND us.active = true
  WHERE c.id = p_creator_id;
  
  -- Pro = unlimited
  IF v_tier = 'pro' THEN
    RETURN true;
  END IF;
  
  -- Free = check quota
  SELECT analyses_used_this_period, analyses_allowed
  INTO v_used, v_allowed
  FROM seo_analysis_quota
  WHERE creator_id = p_creator_id
    AND period_start = date_trunc('week', CURRENT_DATE) -- weekly reset
    AND period_end = date_trunc('week', CURRENT_DATE) + interval '7 days';
  
  -- No record = first use
  IF NOT FOUND THEN
    INSERT INTO seo_analysis_quota (creator_id, user_tier, analyses_allowed, period_start, period_end)
    VALUES (p_creator_id, 'free', 2, date_trunc('week', CURRENT_DATE), date_trunc('week', CURRENT_DATE) + interval '7 days');
    RETURN true;
  END IF;
  
  RETURN v_used < v_allowed;
END;
$$ LANGUAGE plpgsql;

-- Function: Record analysis usage
CREATE OR REPLACE FUNCTION record_seo_analysis(p_creator_id uuid)
RETURNS void AS $$
BEGIN
  UPDATE seo_analysis_quota
  SET 
    analyses_used_this_period = analyses_used_this_period + 1,
    last_analysis_at = now(),
    total_analyses_all_time = total_analyses_all_time + 1
  WHERE creator_id = p_creator_id
    AND period_start = date_trunc('week', CURRENT_DATE);
END;
$$ LANGUAGE plpgsql;
