sql-- Trigger 1: Increment keyword search count when search happens
CREATE OR REPLACE FUNCTION track_keyword_search()
RETURNS TRIGGER AS $$
BEGIN
  INSERT INTO seo_keyword_performance (keyword, searches_total, searches_last_7d, searches_last_30d)
  VALUES (NEW.query_normalized, 1, 1, 1)
  ON CONFLICT (keyword) DO UPDATE
  SET 
    searches_total = seo_keyword_performance.searches_total + 1,
    searches_last_7d = seo_keyword_performance.searches_last_7d + 1,
    searches_last_30d = seo_keyword_performance.searches_last_30d + 1,
    last_updated = now();
    
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_track_keyword
AFTER INSERT ON search_events
FOR EACH ROW
EXECUTE FUNCTION track_keyword_search();

sql-- Trigger 2: Track recipe ranking clicks
CREATE OR REPLACE FUNCTION track_search_click_ranking()
RETURNS TRIGGER AS $$
BEGIN
  -- Update recipe ranking metrics
  UPDATE seo_recipe_rankings
  SET 
    impressions = impressions + 1,
    clicks = clicks + 1,
    click_through_rate = (clicks + 1)::numeric / (impressions + 1),
    last_updated = now()
  WHERE keyword = (SELECT query_normalized FROM search_events WHERE id = NEW.search_event_id)
    AND recipe_id = NEW.recipe_id
    AND ranking_date = CURRENT_DATE;
    
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_track_ranking_click
AFTER INSERT ON search_clicks
FOR EACH ROW
EXECUTE FUNCTION track_search_click_ranking();

