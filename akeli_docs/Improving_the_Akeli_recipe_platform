Data Population Strategy
Daily Cron Job (3am): Update Demographics
sql-- Cron Job: Refresh recipe_demographics
INSERT INTO recipe_demographics (
  recipe_id,
  creator_id,
  total_consumers,
  age_avg,
  age_ranges,
  gender_distribution,
  avg_starting_weight,
  avg_current_weight,
  avg_weight_change,
  goal_distribution,
  activity_distribution,
  avg_weekly_weight_loss,
  success_rate,
  last_updated
)
SELECT 
  r.id as recipe_id,
  r.creator_id,
  COUNT(DISTINCT rc.user_id) as total_consumers,
  
  -- Age metrics
  AVG(EXTRACT(YEAR FROM AGE(CURRENT_DATE, CURRENT_DATE - (uhp.age * interval '1 year')))) as age_avg,
  jsonb_build_object(
    '18-25', COUNT(*) FILTER (WHERE uhp.age BETWEEN 18 AND 25),
    '26-35', COUNT(*) FILTER (WHERE uhp.age BETWEEN 26 AND 35),
    '36-45', COUNT(*) FILTER (WHERE uhp.age BETWEEN 36 AND 45),
    '46-55', COUNT(*) FILTER (WHERE uhp.age BETWEEN 46 AND 55),
    '56+', COUNT(*) FILTER (WHERE uhp.age > 55)
  ) as age_ranges,
  
  -- Gender distribution
  jsonb_build_object(
    'male', COUNT(*) FILTER (WHERE uhp.sex = 'male'),
    'female', COUNT(*) FILTER (WHERE uhp.sex = 'female'),
    'other', COUNT(*) FILTER (WHERE uhp.sex NOT IN ('male', 'female') AND uhp.sex IS NOT NULL),
    'not_specified', COUNT(*) FILTER (WHERE uhp.sex IS NULL)
  ) as gender_distribution,
  
  -- Weight tracking
  AVG(first_weight.weight) as avg_starting_weight,
  AVG(uhp.weight) as avg_current_weight,
  AVG(uhp.weight - first_weight.weight) as avg_weight_change,
  
  -- Goal distribution
  jsonb_build_object(
    'weight_loss', COUNT(*) FILTER (WHERE ug.target_type = 'weight_loss'),
    'muscle_gain', COUNT(*) FILTER (WHERE ug.target_type = 'muscle_gain'),
    'maintenance', COUNT(*) FILTER (WHERE ug.target_type = 'maintenance')
  ) as goal_distribution,
  
  -- Activity levels
  jsonb_build_object(
    'sedentary', COUNT(*) FILTER (WHERE uhp.activity_level = 'sedentary'),
    'light', COUNT(*) FILTER (WHERE uhp.activity_level = 'light'),
    'moderate', COUNT(*) FILTER (WHERE uhp.activity_level = 'moderate'),
    'active', COUNT(*) FILTER (WHERE uhp.activity_level = 'active')
  ) as activity_distribution,
  
  -- Weight loss effectiveness (for weight loss users only)
  AVG(
    CASE 
      WHEN ug.target_type = 'weight_loss' AND first_weight.weight IS NOT NULL
      THEN (first_weight.weight - uhp.weight) / NULLIF(
        EXTRACT(EPOCH FROM (CURRENT_DATE - rc.consumed_at)) / (7 * 24 * 60 * 60), 
        0
      )
      ELSE NULL
    END
  ) as avg_weekly_weight_loss,
  
  -- Success rate
  AVG(
    CASE 
      WHEN ug.target_type = 'weight_loss' 
        AND uhp.weight < first_weight.weight
      THEN 1
      WHEN ug.target_type = 'muscle_gain'
        AND uhp.weight > first_weight.weight
      THEN 1
      WHEN ug.target_type = 'maintenance'
        AND ABS(uhp.weight - first_weight.weight) <= 2
      THEN 1
      ELSE 0
    END
  ) * 100 as success_rate,
  
  now() as last_updated

FROM receipe r
JOIN recipe_consumptions rc ON rc.recipe_id = r.id
JOIN users u ON u.id = rc.user_id
LEFT JOIN user_health_parameter uhp ON uhp.user_id = u.id
LEFT JOIN user_goal ug ON ug.user_id = u.id
LEFT JOIN LATERAL (
  -- Get user's weight when they first cooked this recipe
  SELECT weight 
  FROM updated_weight uw
  WHERE uw.user_id = u.id 
    AND uw.date <= rc.consumed_at::date
  ORDER BY uw.date DESC
  LIMIT 1
) first_weight ON true

GROUP BY r.id, r.creator_id
HAVING COUNT(DISTINCT rc.user_id) >= 10 -- minimum sample size

ON CONFLICT (recipe_id) DO UPDATE
SET 
  total_consumers = EXCLUDED.total_consumers,
  age_avg = EXCLUDED.age_avg,
  age_ranges = EXCLUDED.age_ranges,
  gender_distribution = EXCLUDED.gender_distribution,
  avg_starting_weight = EXCLUDED.avg_starting_weight,
  avg_current_weight = EXCLUDED.avg_current_weight,
  avg_weight_change = EXCLUDED.avg_weight_change,
  goal_distribution = EXCLUDED.goal_distribution,
  activity_distribution = EXCLUDED.activity_distribution,
  avg_weekly_weight_loss = EXCLUDED.avg_weekly_weight_loss,
  success_rate = EXCLUDED.success_rate,
  last_updated = EXCLUDED.last_updated;

