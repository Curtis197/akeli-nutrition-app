sqlCREATE OR REPLACE FUNCTION calculate_recipe_ranking_score(
  p_recipe_id bigint,
  p_user_id bigint DEFAULT NULL
)
RETURNS numeric AS $$
DECLARE
  v_plan_to_cook_score numeric;
  v_quality_score numeric;
  v_discovery_score numeric;
  v_freshness_bonus numeric;
  v_creator_boost numeric;
  v_personalization numeric := 0;
  v_final_score numeric;
BEGIN
  
  -- ========================================
  -- 1. PLAN-TO-COOK RATE (50% weight)
  -- ========================================
  WITH meal_stats AS (
    SELECT 
      -- Last 7 days
      COUNT(*) FILTER (
        WHERE m.meal_date >= CURRENT_DATE - 7
      ) as planned_7d,
      COUNT(*) FILTER (
        WHERE m.meal_date >= CURRENT_DATE - 7 
        AND m.consumed = true
      ) as cooked_7d,
      
      -- Last 30 days
      COUNT(*) FILTER (
        WHERE m.meal_date >= CURRENT_DATE - 30
      ) as planned_30d,
      COUNT(*) FILTER (
        WHERE m.meal_date >= CURRENT_DATE - 30 
        AND m.consumed = true
      ) as cooked_30d,
      
      -- Lifetime
      COUNT(*) as planned_lifetime,
      COUNT(*) FILTER (WHERE m.consumed = true) as cooked_lifetime
    FROM meal m
    WHERE m.receipe_id = p_recipe_id
  )
  SELECT 
    (
      (COALESCE(cooked_7d::numeric / NULLIF(planned_7d, 0), 0) * 0.40) +
      (COALESCE(cooked_30d::numeric / NULLIF(planned_30d, 0), 0) * 0.35) +
      (COALESCE(cooked_lifetime::numeric / NULLIF(planned_lifetime, 0), 0) * 0.25)
    ) * 100
  INTO v_plan_to_cook_score
  FROM meal_stats;
  
  v_plan_to_cook_score := LEAST(COALESCE(v_plan_to_cook_score, 0), 100);
  
  
  -- ========================================
  -- 2. QUALITY SCORE (30% weight) 
  -- ========================================
  SELECT 
    (
      -- 2a. Bayesian average rating (40%)
      (((COALESCE(rpm.avg_rating, 0) * COALESCE(rpm.rating_count, 0) + 4.2 * 10) / 
       (COALESCE(rpm.rating_count, 0) + 10)) / 5.0 * 100 * 0.40) +
      
      -- 2b. Completion rate (35%)
      (COALESCE(rpm.completion_rate, 0) * 0.35) +
      
      -- 2c. Recipe quality metrics (25%)
      ((
        (CASE WHEN COALESCE(
          (SELECT COUNT(*) FROM receipe_image ri WHERE ri.receipe_id = r.id), 0
        ) >= 3 THEN 15
              WHEN COALESCE(
          (SELECT COUNT(*) FROM receipe_image ri WHERE ri.receipe_id = r.id), 0
        ) >= 1 THEN 10
              ELSE 0 END) +
        (CASE WHEN r.time_of_cooking_min > 0 THEN 10 ELSE 5 END) +
        (CASE WHEN EXISTS(
          SELECT 1 FROM ingredients i 
          WHERE i.receipe_id = r.id 
          AND i.quantity IS NOT NULL
        ) THEN 10 ELSE 0 END) +
        (CASE WHEN r.time_of_cooking_min > 0 THEN 5 ELSE 0 END) +
        (CASE WHEN EXISTS(
          SELECT 1 FROM receipe_macro rm 
          WHERE rm.receipe_id = r.id
        ) THEN 5 ELSE 0 END)
      ) / 45.0 * 100 * 0.25)
    )
  INTO v_quality_score
  FROM receipe r
  LEFT JOIN recipe_performance_metrics rpm ON rpm.recipe_id = r.id
  WHERE r.id = p_recipe_id;
  
  v_quality_score := COALESCE(v_quality_score, 0);
  
  
  -- ========================================
  -- 3. DISCOVERY SCORE (15% weight)
  -- ========================================
  WITH discovery_stats AS (
    SELECT 
      -- Impressions (times shown in search)
      COALESCE(SUM(rpm.impressions), 0) as total_impressions,
      
      -- Clicks (from search_clicks or recipe_views from search)
      COALESCE(COUNT(DISTINCT rv.id) FILTER (
        WHERE rv.source = 'search'
      ), 0) as total_clicks,
      
      -- Plans (from meal table)
      COALESCE(COUNT(DISTINCT m.id), 0) as total_plans,
      
      -- Likes
      COALESCE(COUNT(DISTINCT rl.id), 0) as total_likes
      
    FROM recipe_performance_metrics rpm
    LEFT JOIN recipe_views rv ON rv.recipe_id = rpm.recipe_id
    LEFT JOIN meal m ON m.receipe_id = rpm.recipe_id
    LEFT JOIN receipe_likes rl ON rl.receipe_id = rpm.recipe_id
    WHERE rpm.recipe_id = p_recipe_id
  )
  SELECT 
    (
      -- 3a. Click-through rate (50%)
      ((total_clicks::numeric / NULLIF(total_impressions, 0) * 100 * 5) * 0.50) +
      
      -- 3b. Plan rate (30%)
      ((total_plans::numeric / NULLIF(total_clicks, 0) * 100 * 2) * 0.30) +
      
      -- 3c. Like score (20%)
      (((LN(total_likes + 1) * 40) + 
        (total_likes::numeric / NULLIF(total_clicks, 0) * 100 * 60)) * 0.20)
    )
  INTO v_discovery_score
  FROM discovery_stats;
  
  v_discovery_score := LEAST(COALESCE(v_discovery_score, 0), 100);
  
  
  -- ========================================
  -- 4. FRESHNESS BONUS (5% weight)
  -- ========================================
  SELECT 
    CASE
      WHEN CURRENT_DATE - r.created_at::date <= 7 THEN 100
      WHEN CURRENT_DATE - r.created_at::date <= 30 THEN 75
      WHEN CURRENT_DATE - r.created_at::date <= 90 THEN 50
      WHEN CURRENT_DATE - r.created_at::date <= 180 THEN 25
      ELSE 0
    END
  INTO v_freshness_bonus
  FROM receipe r
  WHERE r.id = p_recipe_id;
  
  
  -- ========================================
  -- 5. CREATOR REPUTATION (small boost)
  -- ========================================
  SELECT 
    LEAST(LN(SUM(
      COALESCE((
        SELECT COUNT(*) 
        FROM meal m2 
        WHERE m2.receipe_id = r2.id AND m2.consumed = true
      ), 0)
    ) + 1) * 0.10, 10)
  INTO v_creator_boost
  FROM receipe r
  JOIN receipe r2 ON r2.creator_id = r.creator_id
  WHERE r.id = p_recipe_id;
  
  
  -- ========================================
  -- 6. PERSONALIZATION (Pro users)
  -- ========================================
  IF p_user_id IS NOT NULL THEN
    -- Check if user has Pro subscription
    IF EXISTS(
      SELECT 1 FROM user_subscription us 
      WHERE us.user_id = p_user_id 
      AND us.active = true 
      AND us.plan = 'pro'
    ) THEN
      SELECT 
        (
          (CASE WHEN ug.target_type = rd.primary_user_goal THEN 15 ELSE 0 END) +
          (CASE WHEN NOT EXISTS(
            SELECT 1 FROM user_allergies ua 
            WHERE ua.user_id = p_user_id 
            AND ua.name = ANY(
              SELECT i.name FROM ingredients i WHERE i.receipe_id = r.id
            )
          ) THEN 15 ELSE 0 END) +
          (CASE WHEN r.difficulty <= 3 THEN 10 ELSE 5 END) +
          (CASE WHEN r.time_of_cooking_min <= 45 THEN 10 ELSE 0 END)
        )
      INTO v_personalization
      FROM receipe r
      LEFT JOIN recipe_demographics rd ON rd.recipe_id = r.id
      LEFT JOIN user_goal ug ON ug.user_id = p_user_id
      WHERE r.id = p_recipe_id;
    END IF;
  END IF;
  
  
  -- ========================================
  -- FINAL CALCULATION
  -- ========================================
  v_final_score := 
    (v_plan_to_cook_score * 0.50) +
    (v_quality_score * 0.30) +
    (v_discovery_score * 0.15) +
    (v_freshness_bonus * 0.05) +
    COALESCE(v_creator_boost, 0) +
    (COALESCE(v_personalization, 0) * 0.10);
  
  RETURN ROUND(v_final_score, 2);
  
END;
$$ LANGUAGE plpgsql;

