Algorithme :
typescriptasync function generateShoppingList(
  supabase: any,
  recipeIds: number[],
  servings: number = 1
): Promise<ShoppingList> {
  
  // 1. Fetch tous les ingrédients
  const { data: ingredients } = await supabase
    .from('recipe_ingredient')
    .select('*')
    .in('recipe_id', recipeIds);
  
  // 2. Agrège par ingrédient
  const aggregated = {};
  
  for (const ing of ingredients) {
    const key = ing.ingredient_name.toLowerCase();
    
    if (!aggregated[key]) {
      aggregated[key] = {
        name: ing.ingredient_name,
        total_quantity: 0,
        unit: ing.unit,
        category: ing.category
      };
    }
    
    aggregated[key].total_quantity += ing.quantity * servings;
  }
  
  // 3. Groupe par catégorie
  const byCategory = {};
  
  for (const item of Object.values(aggregated)) {
    if (!byCategory[item.category]) {
      byCategory[item.category] = [];
    }
    byCategory[item.category].push(item);
  }
  
  return byCategory;
}
```

