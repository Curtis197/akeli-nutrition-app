typescriptfunction detectLanguage(message: string): 'fr' | 'en' {
  const frenchWords = ['bonjour', 'merci', 'recette', 'repas', 'kcal'];
  const englishWords = ['hello', 'thanks', 'recipe', 'meal', 'calories'];
  
  const frScore = frenchWords.filter(w => message.toLowerCase().includes(w)).length;
  const enScore = englishWords.filter(w => message.toLowerCase().includes(w)).length;
  
  return enScore > frScore ? 'en' : 'fr';
}

