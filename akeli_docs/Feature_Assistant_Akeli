Implémentation :
typescriptasync function generateMealPlan(
  supabase: any,
  userId: string,
  userContext: UserContextFromUI,
  days: number = 7
): Promise<MealPlan[]> {
  
  const dailyCalories = userContext.target_calorie;
  
  // Répartition standard : 25% petit-déj, 35% déj, 30% dîner, 10% snack
  const mealDistribution = {
    breakfast: dailyCalories * 0.25,
    lunch: dailyCalories * 0.35,
    dinner: dailyCalories * 0.30,
    snack: dailyCalories * 0.10
  };
  
  const plan: MealPlan[] = [];
  
  for (let day = 0; day < days; day++) {
    const dayPlan = {
      day: day + 1,
      meals: []
    };
    
    for (const [mealType, targetCal] of Object.entries(mealDistribution)) {
      // Cherche recette adaptée
      const recipe = await findBestRecipe(supabase, {
        meal_type: mealType,
        target_calories: targetCal,
        user_context: userContext,
        exclude_ids: plan.flatMap(d => d.meals.map(m => m.recipe_id)) // Diversité
      });
      
      dayPlan.meals.push({
        meal_type: mealType,
        recipe_id: recipe.id,
        recipe_name: recipe.name,
        calories: recipe.calorie
      });
    }
    
    plan.push(dayPlan);
  }
  
  return plan;
}
```

